# =============================================================================
# viking-ts server configuration
#
# Copy this file to .env and fill in the values.
# Precedence: environment variables > config file > defaults below
#
# Config file resolution order:
#   1. OPENVIKING_CONFIG_FILE env var
#   2. VIKING_TS_CONFIG_FILE env var
#   3. ~/.viking-ts/config.json
#   4. ~/.openviking/ov.conf (OpenViking fallback)
# =============================================================================

# --- Server -------------------------------------------------------------------

# Host address the server binds to
# Default: 127.0.0.1
HOST=0.0.0.0

# Port the server listens on
# Default: 1934
PORT=1934

# Single API key for root-level authentication.
# If set, all requests must include X-API-Key header (except GET /health).
# Leave empty to disable API key auth.
ROOT_API_KEY=

# CORS allowed origins (comma-separated).
# Default: * (all origins)
CORS_ORIGINS=*

# Node environment (development, production, test)
# In production, Swagger requires SWAGGER_USER/SWAGGER_PASSWORD to be set.
# Default: development
# NODE_ENV=production

# --- Storage ------------------------------------------------------------------

# Storage backend: sqlite (file-based, zero config) or postgres (pgvector)
# Default: sqlite
STORAGE_BACKEND=sqlite

# Base directory for SQLite data (vector indexes, metadata DB).
# STORAGE_WORKSPACE is the preferred name (OpenViking compat).
# STORAGE_PATH also works as a fallback.
# Supports ~ for home directory expansion.
# Default: ~/.viking-ts/data
STORAGE_WORKSPACE=~/.viking-ts/data

# --- PostgreSQL (only when STORAGE_BACKEND=postgres) --------------------------

# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_DATABASE=viking_ts

# Enable TypeORM query logging
# DB_LOGGING=true

# --- Swagger / OpenAPI --------------------------------------------------------

# Enable Swagger UI at /openapi
# Default: false
# SWAGGER_ENABLED=true

# Basic auth credentials for Swagger in production (NODE_ENV=production).
# Both must be set or Swagger is disabled in production.
# SWAGGER_USER=admin
# SWAGGER_PASSWORD=changeme

# --- VLM (Vision Language Model -- for semantic extraction) -------------------
# Used for memory extraction from conversations (session capture) and skills.
# Compatible with any OpenAI-compatible chat completions API.
# VLM_* env vars take priority; LLM_* env vars work as fallback for migration.

# VLM provider identifier (selects the Vercel AI SDK adapter)
# Supported: openai, anthropic
# Default: openai
VLM_PROVIDER=openai

# VLM model name passed to the provider
# Default: gpt-4o-mini
VLM_MODEL=gpt-4o-mini

# API key for the VLM service
# Required for session capture and skill execution
VLM_API_KEY=

# Base URL of the VLM API (only needed for local providers)
# Omit when using openai or anthropic.
VLM_API_BASE=https://api.openai.com/v1

# Enable thinking/reasoning mode (provider must support it)
# Default: false
VLM_THINKING=false

# Maximum concurrent VLM calls (semaphore limit)
# Default: 100
VLM_MAX_CONCURRENT=100

# Enable streaming mode for VLM responses
# Default: false
VLM_STREAM=false

# Extra headers to pass to the VLM API (JSON string)
# VLM_EXTRA_HEADERS={"Authorization":"Bearer token"}

# --- Embedding ----------------------------------------------------------------
# Used to generate vector embeddings for semantic search over memories and
# resources. Compatible with any OpenAI-compatible embedding API.

# Embedding provider label (openai, anthropic, local)
# Default: openai
EMBEDDING_PROVIDER=openai

# Embedding model name passed to the API
# Default: text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-small

# API key for the embedding service
# Required for embedding functionality
EMBEDDING_API_KEY=

# Base URL of the embedding API (only needed for local providers)
# For Ollama: http://localhost:11434/v1
# EMBEDDING_API_BASE=http://localhost:11434/v1

# Vector dimension of the chosen embedding model.
# Default: 1536 (correct for text-embedding-3-small)
EMBEDDING_DIMENSION=1536

# Input type: "text" or "multimodal"
# Default: text
EMBEDDING_INPUT=text

# Batch size for embedding requests
# Default: 32
EMBEDDING_BATCH_SIZE=32

# Maximum concurrent embedding requests
# Default: 10
EMBEDDING_MAX_CONCURRENT=10

# --- Semantic Processing -----------------------------------------------------

# SEMANTIC_MAX_FILE_CONTENT_CHARS=30000
# SEMANTIC_MAX_OVERVIEW_PROMPT_CHARS=60000
# SEMANTIC_OVERVIEW_BATCH_SIZE=50
# SEMANTIC_ABSTRACT_MAX_CHARS=256
# SEMANTIC_OVERVIEW_MAX_CHARS=4000
# SEMANTIC_MEMORY_CHUNK_CHARS=2000
# SEMANTIC_MEMORY_CHUNK_OVERLAP=200

# --- Search ------------------------------------------------------------------

# DEFAULT_SEARCH_MODE=thinking
# DEFAULT_SEARCH_LIMIT=3

# --- Rerank (optional) -------------------------------------------------------
# Optional rerank model for improved retrieval quality.
# Leave RERANK_MODEL empty to disable reranking.

RERANK_MODEL=
RERANK_API_KEY=
RERANK_API_BASE=
RERANK_THRESHOLD=0.1
