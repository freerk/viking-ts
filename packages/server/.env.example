# =============================================================================
# viking-ts server configuration
#
# Copy this file to .env and fill in the values.
# Precedence: environment variables > ~/.viking-ts/config.json > defaults below
# =============================================================================

# --- Server -------------------------------------------------------------------

# Host address the server binds to
# Default: 127.0.0.1
HOST=127.0.0.1

# Port the server listens on
# Default: 1934
PORT=1934

# --- Storage ------------------------------------------------------------------

# Base directory for all persistent data (vector indexes, SQLite metadata DB).
# Supports ~ for home directory expansion.
# Default: ~/.viking-ts/data
STORAGE_PATH=~/.viking-ts/data

# --- Embedding ----------------------------------------------------------------
# Used to generate vector embeddings for semantic search over memories and
# resources. Compatible with any OpenAI-compatible embedding API.

# Embedding provider label (openai, anthropic, local)
# All providers use the OpenAI-compatible API via EMBEDDING_API_BASE,
# so for local providers like Ollama, set EMBEDDING_API_BASE accordingly.
# Default: openai
EMBEDDING_PROVIDER=openai

# Embedding model name passed to the API
# Default: text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-small

# API key for the embedding service
# Required for embedding functionality
EMBEDDING_API_KEY=

# Base URL of the embedding API (only needed for local providers)
# For Ollama: http://localhost:11434/v1
# Omit when using openai or anthropic.
# EMBEDDING_API_BASE=http://localhost:11434/v1

# Vector dimension of the chosen embedding model.
# Must match the output dimension of EMBEDDING_MODEL.
# Default: 1536 (correct for text-embedding-3-small)
EMBEDDING_DIMENSION=1536

# --- LLM ----------------------------------------------------------------------
# Used for memory extraction from conversations (session capture) and skills.
# Compatible with any OpenAI-compatible chat completions API.

# LLM provider identifier (selects the Vercel AI SDK adapter)
# Supported: openai, anthropic
# Default: openai
LLM_PROVIDER=openai

# LLM model name passed to the provider
# Default: gpt-4o-mini
LLM_MODEL=gpt-4o-mini

# API key for the LLM service
# Required for session capture and skill execution
LLM_API_KEY=

# Base URL of the LLM API (only needed for local providers)
# Omit when using openai or anthropic.
# LLM_API_BASE=http://localhost:11434/v1
